# Microsoft Graph (Azure app registration)
# See Prerequisites in claude-plan1.md for setup steps
AZURE_CLIENT_ID=
AZURE_TENANT_ID=consumers

# OneDrive
# Root folder name in your personal OneDrive to watch for guardrail documents
ONEDRIVE_WATCH_FOLDER=Guardrails

# Anthropic
ANTHROPIC_API_KEY=
# Claude model to use for metadata inference (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# GitHub
GITHUB_TOKEN=
# Format: owner/repo — e.g. marktan/guardrails-poc
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# State file path (relative to script root)
STATE_FILE=.guardrails_state.json

# URL sources file path (relative to script root)
URL_SOURCES_FILE=url_sources.json
